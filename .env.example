# ============================================================================
# CINETALES ENVIRONMENT VARIABLES
# ============================================================================
# 1. Copy this file:  cp .env.example .env.local
# 2. Replace each "PASTE_..._HERE" with your real value (keep the quotes)
# 3. Save the file
# ----------------------------------------------------------------------------
# IMPORTANT: Never commit .env.local — it's already in .gitignore
# On Vercel, you'll paste these same values in: Settings -> Environment Variables
# ============================================================================


# --- 1. DATABASE (Supabase pooling URL — port 6543, NOT 5432) ---------------
# Where to get: https://supabase.com -> Project -> Settings -> Database -> Connection Pooling
# Example: postgresql://postgres.abc123:[email protected]:6543/postgres
DATABASE_URL="PASTE_SUPABASE_POOLING_URL_HERE"


# --- 2. NEXTAUTH SECRET (random string for session encryption) --------------
# Where to get: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="PASTE_RANDOM_SECRET_HERE"


# --- 3. NEXTAUTH URL --------------------------------------------------------
# Local dev: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app  (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"


# --- 4. GOOGLE OAUTH (for "Sign in with Google") ----------------------------
# Where to get: https://console.cloud.google.com -> APIs & Services -> Credentials
# Don't forget to add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="PASTE_GOOGLE_CLIENT_ID_HERE"
GOOGLE_CLIENT_SECRET="PASTE_GOOGLE_CLIENT_SECRET_HERE"


# --- 5. TMDB API (movie data) ----------------------------------------------
# Where to get: https://www.themoviedb.org/settings/api
# Use the v4 "API Read Access Token" (long JWT starting with eyJ), NOT v3 key
TMDB_BEARER_TOKEN="PASTE_TMDB_BEARER_TOKEN_HERE"


# --- 6. GROQ AI (free Llama 3.3 — powers Vibes, AI Chat, Recommendations) --
# Where to get: https://console.groq.com/keys
# Free tier: 14,400 req/day, 30 req/min
# Without this, the AI features won't work but the rest of the app is fine.
GROQ_API_KEY="PASTE_GROQ_API_KEY_HERE"
