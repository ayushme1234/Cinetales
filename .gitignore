# ==============================================================
# DEPENDENCIES
# ==============================================================
node_modules
.pnp
.pnp.js
.yarn/install-state.gz

# ==============================================================
# NEXT.JS BUILD OUTPUT
# ==============================================================
.next/
out/
build/
dist/

# ==============================================================
# ENVIRONMENT VARIABLES — NEVER COMMIT THESE
# ==============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ==============================================================
# VERCEL
# ==============================================================
.vercel

# ==============================================================
# DEBUG / LOGS
# ==============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ==============================================================
# TYPESCRIPT
# ==============================================================
*.tsbuildinfo
next-env.d.ts.bak

# ==============================================================
# PRISMA — generated client (regenerated on each build)
# ==============================================================
# prisma/migrations is COMMITTED on purpose. Don't add it here.

# ==============================================================
# IDE / EDITOR
# ==============================================================
.vscode/
.idea/
*.swp
*.swo
.fleet/

# ==============================================================
# OPERATING SYSTEM
# ==============================================================
.DS_Store
Thumbs.db
desktop.ini

# ==============================================================
# TEMPORARY FILES
# ==============================================================
*.tmp
*.temp
.cache/
